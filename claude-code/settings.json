{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "effortLevel": "medium",
  "showTurnDuration": true,
  "includeGitInstructions": false,
  "attribution": {
    "commit": "Co-Authored-By: Claude Sonnet 4.5 <noreply@anthropic.com>"
  },
  "statusLine": {
    "type": "command",
    "command": "/home/ortho/.config/home-manager/claude-code/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '/home/ortho/.config/home-manager/scripts/peon-sound.sh session.start &'"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ortho/.config/home-manager/scripts/inject-project-context.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '/home/ortho/.config/home-manager/scripts/claude-notify.sh'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(home-manager switch)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '/usr/bin/notify-send \"Home Manager\" \"Configuration applied successfully!\" -t 5000 -u normal; /home/ortho/.config/home-manager/scripts/peon-sound.sh task.complete &'"
          }
        ]
      },
      {
        "matcher": "Bash(home-manager build)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '/usr/bin/notify-send \"Home Manager\" \"Build completed successfully\" -t 3000 -u low; /home/ortho/.config/home-manager/scripts/peon-sound.sh task.acknowledge &'"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash(home-manager *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '/usr/bin/notify-send \"Home Manager\" \"Build/switch failed! Check errors.\" -t 5000 -u critical; /home/ortho/.config/home-manager/scripts/peon-sound.sh task.error &'"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "mcpvault": {
      "command": "npx",
      "args": ["@bitbonsai/mcpvault@latest", "/home/ortho/Orthidian"],
      "env": {}
    }
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "additionalDirectories": ["~/Orthidian"],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ],
    "allow": [
      "Read",
      "WebSearch",
      "WebFetch",

      "Bash(*)",

      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(sed *)",
